# ASCENT Course — Environment Variables
# Copy to .env and fill in your keys

# LLM providers (required for Modules 5-6: Kaizen agents, Align fine-tuning)
OPENAI_API_KEY=
OPENAI_PROD_MODEL=gpt-4o
DEFAULT_LLM_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Google Drive (optional — data loader uses public folder by default)
# GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# Database (optional — defaults to SQLite for exercises)
# DATABASE_URL=sqlite:///ascent.db

# HuggingFace (required for Module 6: Align fine-tuning)
HF_TOKEN=
